# ============================================================
# LandSignal AI — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
# ============================================================

# --- Database ---
# SQLite (default — leave unset for local dev)
# DATABASE_URL=sqlite:///./landsignal.db

# Postgres + PostGIS (Railway / production)
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/landsignal

# --- Security ---
# Admin API key for /admin/* endpoints (leave empty to disable auth in dev)
ADMIN_API_KEY=

# JWT secret for user auth (Phase B+) — must be ≥32 chars in production
JWT_SECRET=change-me-in-production

# --- Razorpay (Phase B) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Email / Alerts (Phase D) ---
# Resend API key (https://resend.com — free tier: 3000 emails/month)
RESEND_API_KEY=

# SendGrid fallback
SENDGRID_API_KEY=

# WhatsApp via Interakt (Phase D)
INTERAKT_API_KEY=

# --- PDF Reports (Phase C) ---
# Local storage path for generated PDFs
REPORTS_DIR=./reports/generated

# --- Sentry (Phase G) ---
SENTRY_DSN=

# --- External APIs ---
# OpenStreetMap Overpass — no key needed (public free tier)
OVERPASS_URL=https://overpass-api.de/api/interpreter

# --- App config ---
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Deploy (Phase G) ---
# Set this to your Vercel frontend URL so the Railway backend allows it in CORS
FRONTEND_URL=https://your-app.vercel.app

# --- Frontend (set in Vercel dashboard → Settings → Environment Variables) ---
# VITE_API_BASE_URL=https://YOUR_APP.railway.app
